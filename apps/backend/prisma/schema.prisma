generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Video {
  id            String         @id @default(uuid())
  title         String         @unique @db.VarChar(255)
  subtitle      String?        @db.VarChar(255)
  description   String?
  year          Int?
  coverImage    String?        @map("cover_image")
  status        Int            @default(1)
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  categoryId    String?        @map("category_id")
  category      Category?      @relation(fields: [categoryId], references: [id])
  videoSources  VideoSource[]
  videoTags     VideoTag[]
  favorites     UserFavorite[]
  histories     UserHistory[]

  @@index([status])
  @@index([year])
  @@map("videos")
}

model VideoSource {
  id          String         @id @default(uuid())
  videoId     String         @map("video_id")
  name        String         @db.VarChar(100)
  sourceType  String         @map("source_type") @db.VarChar(20)
  sortOrder   Int            @default(0) @map("sort_order")
  status      Int            @default(1)
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")
  video       Video          @relation(fields: [videoId], references: [id], onDelete: Cascade)
  episodes    VideoEpisode[]

  @@index([videoId])
  @@index([status])
  @@map("video_sources")
}

model VideoEpisode {
  id           String      @id @default(uuid())
  videoSourceId String     @map("video_source_id")
  title        String      @db.VarChar(255)
  episodeNo    Int         @map("episode_no")
  playUrl      String      @map("play_url")
  status       Int         @default(1)
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")
  videoSource  VideoSource @relation(fields: [videoSourceId], references: [id], onDelete: Cascade)

  @@unique([videoSourceId, episodeNo])
  @@index([status])
  @@map("video_episodes")
}

model Category {
  id         String      @id @default(uuid())
  parentId   String?     @map("parent_id")
  name       String      @unique @db.VarChar(100)
  sortOrder  Int         @default(0) @map("sort_order")
  status     Int         @default(1)
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")
  parent     Category?   @relation("CategoryTree", fields: [parentId], references: [id])
  children   Category[]  @relation("CategoryTree")
  videos     Video[]

  @@index([parentId])
  @@index([status])
  @@map("categories")
}

model Tag {
  id         String      @id @default(uuid())
  name       String      @unique @db.VarChar(100)
  status     Int         @default(1)
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")
  videoTags  VideoTag[]

  @@index([status])
  @@map("tags")
}

model VideoTag {
  id         String    @id @default(uuid())
  videoId    String    @map("video_id")
  tagId      String    @map("tag_id")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  video      Video     @relation(fields: [videoId], references: [id], onDelete: Cascade)
  tag        Tag       @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([videoId, tagId])
  @@index([tagId])
  @@map("video_tags")
}

model User {
  id          String          @id @default(uuid())
  email       String          @unique @db.VarChar(255)
  username    String          @unique @db.VarChar(50)
  password    String          @db.VarChar(255)
  role        String          @default("USER") @db.VarChar(20)
  vipExpireAt DateTime?       @map("vip_expire_at")
  status      Int             @default(1)
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  favorites   UserFavorite[]
  histories   UserHistory[]

  @@index([status])
  @@map("users")
}

model UserFavorite {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  videoId    String    @map("video_id")
  status     Int       @default(1)
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  video      Video     @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([userId, videoId])
  @@index([videoId])
  @@index([status])
  @@map("user_favorites")
}

model UserHistory {
  id            String    @id @default(uuid())
  userId         String    @map("user_id")
  videoId        String    @map("video_id")
  episodeId      String?   @map("episode_id")
  progressSecond Int       @default(0) @map("progress_second")
  watchedAt      DateTime  @default(now()) @map("watched_at")
  status         Int       @default(1)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  video          Video     @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@index([userId, watchedAt])
  @@index([status])
  @@map("user_history")
}

model CollectRule {
  id            String    @id @default(uuid())
  name          String    @unique @db.VarChar(100)
  sourceUrl     String    @map("source_url")
  sourceType    String    @map("source_type") @db.VarChar(20)
  cronExpr      String?   @map("cron_expr") @db.VarChar(100)
  maxItems      Int       @default(100) @map("max_items")
  minIntervalMs Int       @default(300000) @map("min_interval_ms")
  status        Int       @default(1)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  logs          CollectLog[]

  @@index([status])
  @@map("collect_rules")
}

model CollectLog {
  id          String      @id @default(uuid())
  ruleId      String      @map("rule_id")
  status      String      @db.VarChar(20)
  triggerType String      @map("trigger_type") @db.VarChar(20)
  message     String?
  total       Int         @default(0)
  created     Int         @default(0)
  skipped     Int         @default(0)
  failed      Int         @default(0)
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  rule        CollectRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([ruleId, createdAt])
  @@index([status])
  @@map("collect_logs")
}
